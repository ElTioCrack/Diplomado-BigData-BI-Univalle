# =================================================================
# REPOSITORIO: DIPLOMADO BIG DATA, ANALYTICS & BI
# =================================================================

# --- Python & Virtual Environments ---
# Ignora entornos virtuales sin importar el nombre común
.venv/
venv/
env/
ENV/
build/
dist/
*.egg-info/
__pycache__/
*.py[cod]
*$py.class

# --- Jupyter Notebooks ---
# Ignora archivos temporales y checkpoints de guardado automático
.ipynb_checkpoints/
.virtual_documents/
.ipynb/

# --- Multimedia & Class Recordings ---
# Bloqueo total de archivos de video pesados en cualquier subcarpeta
*.mp4
*.mkv
*.avi
*.mov
*.wmv
*.flv

# --- Compressed & Large Data Files ---
# Ignora archivos comprimidos (comúnmente usados para datasets pesados)
*.zip
*.rar
*.7z
*.tar
*.gz

# --- Databases & Local Secrets ---
# Ignora bases de datos locales y variables de entorno sensibles
*.sqlite3
*.db
*.sql
.env
.flaskenv

# --- IDEs & System Garbage ---
# Microsoft Visual Studio Code
.vscode/
!.vscode/settings.json
!.vscode/tasks.json
!.vscode/launch.json
!.vscode/extensions.json

# JetBrains (PyCharm, IntelliJ)
.idea/

# Windows / macOS System files
Thumbs.db
desktop.ini
.DS_Store

# --- Academic Resources (Optional) ---
# Descomenta la siguiente línea si quieres ignorar PDFs pesados en /recursos
# *.pdf